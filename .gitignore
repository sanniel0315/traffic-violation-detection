# Python
__pycache__/
*.py[cod]
*.so
.env
venv/
.venv/

# --- 每台機器自己管的目錄（實體 dir 或 symlink 都可）---
# 以 /xxx 開頭 = 只忽略 repo 根目錄下的同名目錄，不影響子層命名一樣的檔案
/data
/models
/output
/storage

# 大檔案殘留保險（萬一有人不小心放在別的路徑）
*.pt
*.engine
*.onnx
data/*.db
data/*.sqlite
data/*.sqlite3
data/*.db-*
data/*.sqlite-*

# Frigate runtime state
config/frigate/*.db*
config/frigate/.search_stats.json
config/frigate/.vacuum
config/frigate/backup_config.yaml

# Per-machine runtime settings (contains client_id / broker IP)
config/system/mqtt_settings.json

# Training / test artefacts
datasets/
test_snapshots/

# 測試檔案
*.mp4
*.avi
*.mkv
source/

# IDE
.vscode/
.idea/

# Git backup
.git_backup/

# Logs
*.log
nohup.out

# --- local backups / temp ---
*.bak
*.bak*
*backup*
backups/
backup.sh
!scripts/settings_backup.py
web/index_*
config/frigate/.vacuum

# --- python ---
__pycache__/
*.pyc
.venv/
venv/

# --- logs / runs ---
logs/
runs/
output/
recordings/

# --- settings backup (track this file) ---
!config/settings_backup.json
data/violations.db.bak
