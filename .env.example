# 時區
TZ=Asia/Taipei

# Frigate
FRIGATE_RTSP_PASSWORD=

# Model paths
# MODEL_DIR 預設模型目錄；DETECT_MODEL_* 可填絕對路徑或檔名/相對路徑
MODEL_DIR=/workspace/models
DETECT_MODEL_ENGINE=yolov8n.engine
DETECT_MODEL_PT=yolov8n.pt

# 資料庫 (可選)
# DATABASE_URL=postgresql://user:pass@localhost:5432/traffic

# MQTT (可選)
# MQTT_HOST=localhost
# MQTT_PORT=1883
